{
  "name": "author-kit",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.1.0",
  "bundledApiVersion": "0.1.0",
  "license": "MIT",
  "author": "Julien Moulin <julien@supralab.fr>",
  "repository": {
    "type": "git",
    "url": "https://github.com/SupraLab/authorkit.git",
    "directory": "plugin"
  },
  "bugs": {
    "url": "https://github.com/SupraLab/authorkit/issues"
  },
  "homepage": "https://github.com/SupraLab/authorkit#readme",
  "publisher": "authorkit",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "authorkit.apiBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8765",
          "description": "%config.apiBaseUrl%"
        },
        "authorkit.worldCategoryName": {
          "type": "string",
          "default": "World",
          "description": "%config.worldCategoryName%"
        },
        "authorkit.charactersCategoryName": {
          "type": "string",
          "default": "Characters",
          "description": "%config.charactersCategoryName%"
        },
        "authorkit.activeLlmProfile": {
          "type": "string",
          "default": "",
          "description": "%config.activeLlmProfile%"
        },
        "authorkit.workshopModelOverride": {
          "type": "string",
          "default": "",
          "description": "%config.workshopModelOverride%"
        },
        "authorkit.selectionCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "%config.selectionCodeLens%"
        },
        "authorkit.startLocalApi": {
          "type": "boolean",
          "default": false,
          "description": "%config.startLocalApi%"
        },
        "authorkit.localApiPort": {
          "type": "number",
          "default": 8765,
          "description": "%config.localApiPort%"
        },
        "authorkit.localApiBinaryPath": {
          "type": "string",
          "default": "",
          "description": "%config.localApiBinaryPath%"
        },
        "authorkit.githubApiReleaseTag": {
          "type": "string",
          "default": "",
          "description": "%config.githubApiReleaseTag%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "authorkit-sidebar",
          "title": "%viewContainer.sidebar%",
          "icon": "media/icon.svg"
        }
      ],
      "auxiliarybar": [
        {
          "id": "authorkit-workshop",
          "title": "%viewContainer.workshop%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "authorkit-sidebar": [
        {
          "id": "authorkit.outline",
          "name": "%view.bookStructure%"
        },
        {
          "id": "authorkit.characters",
          "name": "%view.characters%"
        },
        {
          "id": "authorkit.world",
          "name": "%view.world%"
        }
      ],
      "authorkit-workshop": [
        {
          "id": "authorkit.workshopView",
          "name": "%view.workshopPanel%",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "authorkit.refresh",
        "title": "%command.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "authorkit.createCharacter",
        "title": "%command.createCharacter%",
        "icon": "$(add)"
      },
      {
        "command": "authorkit.createWorldEntry",
        "title": "%command.createWorldEntry%",
        "icon": "$(add)"
      },
      {
        "command": "authorkit.openScene",
        "title": "%command.openScene%"
      },
      {
        "command": "authorkit.openEntryDetail",
        "title": "%command.openEntry%"
      },
      {
        "command": "authorkit.openWorkshop",
        "title": "%command.openWorkshop%",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "authorkit.addSelectionToWorkshop",
        "title": "%command.addSelectionToWorkshop%",
        "icon": "$(selection)"
      },
      {
        "command": "authorkit.openCompendiumChat",
        "title": "%command.openCompendiumChat%"
      },
      {
        "command": "authorkit.testConnection",
        "title": "%command.testConnection%"
      },
      {
        "command": "authorkit.redownloadApi",
        "title": "%command.redownloadApi%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "authorkit.initWorkspace",
        "title": "%command.initWorkspace%",
        "icon": "$(new-folder)"
      },
      {
        "command": "authorkit.openLlmSettings",
        "title": "%command.openLlmSettings%",
        "icon": "$(settings-gear)"
      },
      {
        "command": "authorkit.renameStructureNode",
        "title": "%command.renameStructureNode%",
        "icon": "$(edit)"
      },
      {
        "command": "authorkit.addAct",
        "title": "%command.addAct%",
        "icon": "$(add)"
      },
      {
        "command": "authorkit.addChapter",
        "title": "%command.addChapter%",
        "icon": "$(add)"
      },
      {
        "command": "authorkit.addScene",
        "title": "%command.addScene%",
        "icon": "$(add)"
      },
      {
        "command": "authorkit.deleteStructureNode",
        "title": "%command.deleteStructureNode%",
        "icon": "$(trash)"
      },
      {
        "command": "authorkit.moveStructureUp",
        "title": "%command.moveStructureUp%",
        "icon": "$(arrow-up)"
      },
      {
        "command": "authorkit.moveStructureDown",
        "title": "%command.moveStructureDown%",
        "icon": "$(arrow-down)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "authorkit.addSelectionToWorkshop",
          "when": "editorTextFocus && editorHasSelection && workspaceFolderCount > 0",
          "group": "navigation@82"
        }
      ],
      "editor/context": [
        {
          "command": "authorkit.addSelectionToWorkshop",
          "when": "editorTextFocus && editorHasSelection && workspaceFolderCount > 0",
          "group": "9_authorkit@1"
        }
      ],
      "view/title": [
        {
          "command": "authorkit.refresh",
          "when": "view =~ /^authorkit\\./",
          "group": "navigation"
        },
        {
          "command": "authorkit.openWorkshop",
          "when": "view =~ /^authorkit\\./ && workspaceFolderCount > 0",
          "group": "navigation@0"
        },
        {
          "command": "authorkit.initWorkspace",
          "when": "view == authorkit.outline && !authorkit.hasProject",
          "group": "navigation@2"
        },
        {
          "command": "authorkit.openLlmSettings",
          "when": "view == authorkit.outline",
          "group": "navigation@3"
        },
        {
          "command": "authorkit.redownloadApi",
          "when": "view == authorkit.outline && config.authorkit.startLocalApi",
          "group": "navigation@5"
        },
        {
          "command": "authorkit.addAct",
          "when": "view == authorkit.outline && workspaceFolderCount > 0",
          "group": "navigation@4"
        },
        {
          "command": "authorkit.createCharacter",
          "when": "view == authorkit.characters",
          "group": "navigation@1"
        },
        {
          "command": "authorkit.createWorldEntry",
          "when": "view == authorkit.world",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "authorkit.renameStructureNode",
          "when": "view == authorkit.outline && viewItem =~ /authorkit\\.(act|chapter|scene)/",
          "group": "1_modification@1"
        },
        {
          "command": "authorkit.addChapter",
          "when": "view == authorkit.outline && viewItem =~ /authorkit\\.(act|chapter)/",
          "group": "2_structure@1"
        },
        {
          "command": "authorkit.addScene",
          "when": "view == authorkit.outline && viewItem =~ /authorkit\\.(chapter|scene)/",
          "group": "2_structure@2"
        },
        {
          "command": "authorkit.moveStructureUp",
          "when": "view == authorkit.outline && viewItem =~ /authorkit\\.(act|chapter|scene)/",
          "group": "3_structure@1"
        },
        {
          "command": "authorkit.moveStructureDown",
          "when": "view == authorkit.outline && viewItem =~ /authorkit\\.(act|chapter|scene)/",
          "group": "3_structure@2"
        },
        {
          "command": "authorkit.deleteStructureNode",
          "when": "view == authorkit.outline && viewItem =~ /authorkit\\.(act|chapter|scene)/",
          "group": "4_structure@1"
        },
        {
          "command": "authorkit.openCompendiumChat",
          "when": "view == authorkit.characters && viewItem == authorkit.compentry",
          "group": "0_chat@1"
        },
        {
          "command": "authorkit.openCompendiumChat",
          "when": "view == authorkit.world && viewItem == authorkit.compentry",
          "group": "0_chat@1"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "authorkit.author-kit",
        "name": "authorKit",
        "fullName": "AuthorKit",
        "description": "%chat.participant.description%",
        "isSticky": true
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.90.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.17.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.0.0"
  }
}
